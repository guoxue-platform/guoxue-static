  "records": [
    {
      "文本": "天行健，君子以自强不息。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《周易·乾卦》",
      "出处/作者": "《周易·乾卦》"
    },
    {
      "文本": "地势坤，君子以厚德载物。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《周易·坤卦》",
      "出处/作者": "《周易·坤卦》"
    },
    {
      "文本": "穷则变，变则通，通则久。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《周易·系辞》",
      "出处/作者": "《周易·系辞》"
    },
    {
      "文本": "二人同心，其利断金。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《周易·系辞》",
      "出处/作者": "《周易·系辞》"
    },
    {
      "文本": "孟子见梁惠王。王曰：\"叟！不远千里而来，亦将有以利吾国乎？\"",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《孟子·梁惠王上》",
      "出处/作者": "《孟子·梁惠王上》"
    },
    {
      "文本": "老吾老，以及人之老；幼吾幼，以及人之幼。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《孟子·梁惠王上》",
      "出处/作者": "《孟子·梁惠王上》"
    },
    {
      "文本": "权，然后知轻重；度，然后知长短。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《孟子·梁惠王上》",
      "出处/作者": "《孟子·梁惠王上》"
    },
    {
      "文本": "天时不如地利，地利不如人和。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《孟子·公孙丑下》",
      "出处/作者": "《孟子·公孙丑下》"
    },
    {
      "文本": "得道者多助，失道者寡助。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《孟子·公孙丑下》",
      "出处/作者": "《孟子·公孙丑下》"
    },
    {
      "文本": "富贵不能淫，贫贱不能移，威武不能屈，此之谓大丈夫。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《孟子·滕文公下》",
      "出处/作者": "《孟子·滕文公下》"
    },
    {
      "文本": "生于忧患，死于安乐。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《孟子·告子下》",
      "出处/作者": "《孟子·告子下》"
    },
    {
      "文本": "鱼，我所欲也；熊掌，亦我所欲也。二者不可得兼，舍鱼而取熊掌者也。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《孟子·告子上》",
      "出处/作者": "《孟子·告子上》"
    },
    {
      "文本": "人性之善也，犹水之就下也。人无有不善，水无有不下。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《孟子·告子上》",
      "出处/作者": "《孟子·告子上》"
    },
    {
      "文本": "故天将降大任于是人也，必先苦其心志，劳其筋骨，饿其体肤，空乏其身。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《孟子·告子下》",
      "出处/作者": "《孟子·告子下》"
    },
    {
      "文本": "克勤于邦，克俭于家。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《尚书·大禹谟》",
      "出处/作者": "《尚书·大禹谟》"
    },
    {
      "文本": "玩人丧德，玩物丧志。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《尚书·旅獒》",
      "出处/作者": "《尚书·旅獒》"
    },
    {
      "文本": "人心惟危，道心惟微，惟精惟一，允执厥中。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《尚书·大禹谟》",
      "出处/作者": "《尚书·大禹谟》"
    },
    {
      "文本": "满招损，谦受益，时乃天道。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《尚书·大禹谟》",
      "出处/作者": "《尚书·大禹谟》"
    },
    {
      "文本": "礼尚往来。往而不来，非礼也；来而不往，亦非礼也。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《礼记·曲礼》",
      "出处/作者": "《礼记·曲礼》"
    },
    {
      "文本": "玉不琢，不成器；人不学，不知道。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《礼记·学记》",
      "出处/作者": "《礼记·学记》"
    },
    {
      "文本": "独学而无友，则孤陋而寡闻。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《礼记·学记》",
      "出处/作者": "《礼记·学记》"
    },
    {
      "文本": "凡事预则立，不预则废。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《礼记·中庸》",
      "出处/作者": "《礼记·中庸》"
    },
    {
      "文本": "一张一弛，文武之道也。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《礼记·杂记》",
      "出处/作者": "《礼记·杂记》"
    },
    {
      "文本": "学而时习之，不亦说乎？",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《论语·学而》",
      "出处/作者": "《论语·学而》"
    },
    {
      "文本": "吾十有五而志于学，三十而立，四十而不惑，五十而知天命，六十而耳顺，七十而从心所欲，不逾矩。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《论语·为政》",
      "出处/作者": "《论语·为政》"
    },
    {
      "文本": "温故而知新，可以为师矣。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《论语·为政》",
      "出处/作者": "《论语·为政》"
    },
    {
      "文本": "知之为知之，不知为不知，是知也。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《论语·为政》",
      "出处/作者": "《论语·为政》"
    },
    {
      "文本": "学而不思则罔，思而不学则殆。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《论语·为政》",
      "出处/作者": "《论语·为政》"
    },
    {
      "文本": "君子周而不比，小人比而不周。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《论语·为政》",
      "出处/作者": "《论语·为政》"
    },
    {
      "文本": "人而无信，不知其可也。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《论语·为政》",
      "出处/作者": "《论语·为政》"
    },
    {
      "文本": "《关雎》乐而不淫，哀而不伤。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《论语·八佾》",
      "出处/作者": "《论语·八佾》"
    },
    {
      "文本": "里仁为美，择不处仁，焉得知？",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《论语·里仁》",
      "出处/作者": "《论语·里仁》"
    },
    {
      "文本": "君子喻于义，小人喻于利。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《论语·里仁》",
      "出处/作者": "《论语·里仁》"
    },
    {
      "文本": "关关雎鸠，在河之洲。窈窕淑女，君子好逑。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《诗经·周南·关雎》",
      "出处/作者": "《诗经·周南·关雎》"
    },
    {
      "文本": "蒹葭苍苍，白露为霜。所谓伊人，在水一方。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《诗经·秦风·蒹葭》",
      "出处/作者": "《诗经·秦风·蒹葭》"
    },
    {
      "文本": "死生契阔，与子成说。执子之手，与子偕老。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《诗经·邶风·击鼓》",
      "出处/作者": "《诗经·邶风·击鼓》"
    },
    {
      "文本": "它山之石，可以攻玉。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《诗经·小雅·鹤鸣》",
      "出处/作者": "《诗经·小雅·鹤鸣》"
    },
    {
      "文本": "知我者，谓我心忧；不知我者，谓我何求。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《诗经·王风·黍离》",
      "出处/作者": "《诗经·王风·黍离》"
    },
    {
      "文本": "桃之夭夭，灼灼其华。之子于归，宜其室家。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《诗经·周南·桃夭》",
      "出处/作者": "《诗经·周南·桃夭》"
    },
    {
      "文本": "投我以木瓜，报之以琼琚。匪报也，永以为好也。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《诗经·卫风·木瓜》",
      "出处/作者": "《诗经·卫风·木瓜》"
    },
    {
      "文本": "战战兢兢，如临深渊，如履薄冰。",
      "类别": "名句",
      "四部分类": "经部",
      "标题": "《诗经·小雅·小旻》",
      "出处/作者": "《诗经·小雅·小旻》"
    },
    {
      "文本": "海内存知己，天涯若比邻。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "王勃《送杜少府之任蜀州》",
      "出处/作者": "王勃《送杜少府之任蜀州》"
    },
    {
      "文本": "落霞与孤鹜齐飞，秋水共长天一色。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "王勃《滕王阁序》",
      "出处/作者": "王勃《滕王阁序》"
    },
    {
      "文本": "春江潮水连海平，海上明月共潮生。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "张若虚《春江花月夜》",
      "出处/作者": "张若虚《春江花月夜》"
    },
    {
      "文本": "人生代代无穷已，江月年年望相似。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "张若虚《春江花月夜》",
      "出处/作者": "张若虚《春江花月夜》"
    },
    {
      "文本": "欲穷千里目，更上一层楼。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "王之涣《登鹳雀楼》",
      "出处/作者": "王之涣《登鹳雀楼》"
    },
    {
      "文本": "羌笛何须怨杨柳，春风不度玉门关。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "王之涣《凉州词》",
      "出处/作者": "王之涣《凉州词》"
    },
    {
      "文本": "黄沙百战穿金甲，不破楼兰终不还。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "王昌龄《从军行》",
      "出处/作者": "王昌龄《从军行》"
    },
    {
      "文本": "但使龙城飞将在，不教胡马度阴山。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "王昌龄《出塞》",
      "出处/作者": "王昌龄《出塞》"
    },
    {
      "文本": "洛阳亲友如相问，一片冰心在玉壶。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "王昌龄《芙蓉楼送辛渐》",
      "出处/作者": "王昌龄《芙蓉楼送辛渐》"
    },
    {
      "文本": "空山不见人，但闻人语响。返景入深林，复照青苔上。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "王维《鹿柴》",
      "出处/作者": "王维《鹿柴》"
    },
    {
      "文本": "大漠孤烟直，长河落日圆。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "王维《使至塞上》",
      "出处/作者": "王维《使至塞上》"
    },
    {
      "文本": "明月松间照，清泉石上流。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "王维《山居秋暝》",
      "出处/作者": "王维《山居秋暝》"
    },
    {
      "文本": "独在异乡为异客，每逢佳节倍思亲。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "王维《九月九日忆山东兄弟》",
      "出处/作者": "王维《九月九日忆山东兄弟》"
    },
    {
      "文本": "蜀道之难，难于上青天！",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "李白《蜀道难》",
      "出处/作者": "李白《蜀道难》"
    },
    {
      "文本": "君不见黄河之水天上来，奔流到海不复回。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "李白《将进酒》",
      "出处/作者": "李白《将进酒》"
    },
    {
      "文本": "人生得意须尽欢，莫使金樽空对月。天生我材必有用，千金散尽还复来。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "李白《将进酒》",
      "出处/作者": "李白《将进酒》"
    },
    {
      "文本": "举杯邀明月，对影成三人。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "李白《月下独酌》",
      "出处/作者": "李白《月下独酌》"
    },
    {
      "文本": "安能摧眉折腰事权贵，使我不得开心颜！",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "李白《梦游天姥吟留别》",
      "出处/作者": "李白《梦游天姥吟留别》"
    },
    {
      "文本": "无边落木萧萧下，不尽长江滚滚来。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "杜甫《登高》",
      "出处/作者": "杜甫《登高》"
    },
    {
      "文本": "风急天高猿啸哀，渚清沙白鸟飞回。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "杜甫《登高》",
      "出处/作者": "杜甫《登高》"
    },
    {
      "文本": "艰难苦恨繁霜鬓，潦倒新停浊酒杯。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "杜甫《登高》",
      "出处/作者": "杜甫《登高》"
    },
    {
      "文本": "国破山河在，城春草木深。感时花溅泪，恨别鸟惊心。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "杜甫《春望》",
      "出处/作者": "杜甫《春望》"
    },
    {
      "文本": "烽火连三月，家书抵万金。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "杜甫《春望》",
      "出处/作者": "杜甫《春望》"
    },
    {
      "文本": "会当凌绝顶，一览众山小。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "杜甫《望岳》",
      "出处/作者": "杜甫《望岳》"
    },
    {
      "文本": "朱门酒肉臭，路有冻死骨。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "杜甫《自京洛奉先县咏怀五百字》",
      "出处/作者": "杜甫《自京洛奉先县咏怀五百字》"
    },
    {
      "文本": "正是江南好风景，落花时节又逢君。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "杜甫《江南逢李龟年》",
      "出处/作者": "杜甫《江南逢李龟年》"
    },
    {
      "文本": "旧时王谢堂前燕，飞入寻常百姓家。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "刘禹锡《乌衣巷》",
      "出处/作者": "刘禹锡《乌衣巷》"
    },
    {
      "文本": "山不在高，有仙则名；水不在深，有龙则灵。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "刘禹锡《陋室铭》",
      "出处/作者": "刘禹锡《陋室铭》"
    },
    {
      "文本": "千淘万漉虽辛苦，吹尽狂沙始到金。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "刘禹锡《浪淘沙》",
      "出处/作者": "刘禹锡《浪淘沙》"
    },
    {
      "文本": "同是天涯沦落人，相逢何必曾相识。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "白居易《琵琶行》",
      "出处/作者": "白居易《琵琶行》"
    },
    {
      "文本": "座中泣下谁最多？江州司马青衫湿。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "白居易《琵琶行》",
      "出处/作者": "白居易《琵琶行》"
    },
    {
      "文本": "离离原上草，一岁一枯荣。野火烧不尽，春风吹又生。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "白居易《赋得古原草送别》",
      "出处/作者": "白居易《赋得古原草送别》"
    },
    {
      "文本": "日出江花红胜火，春来江水绿如蓝。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "白居易《忆江南》",
      "出处/作者": "白居易《忆江南》"
    },
    {
      "文本": "曾经沧海难为水，除却巫山不是云。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "元稹《离思》",
      "出处/作者": "元稹《离思》"
    },
    {
      "文本": "贫贱夫妻百事哀。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "元稹《遣悲怀》",
      "出处/作者": "元稹《遣悲怀》"
    },
    {
      "文本": "春蚕到死丝方尽，蜡炬成灰泪始干。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "李商隐《无题》",
      "出处/作者": "李商隐《无题》"
    },
    {
      "文本": "身无彩凤双飞翼，心有灵犀一点通。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "李商隐《无题》",
      "出处/作者": "李商隐《无题》"
    },
    {
      "文本": "夕阳无限好，只是近黄昏。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "李商隐《乐游原》",
      "出处/作者": "李商隐《乐游原》"
    },
    {
      "文本": "何当共剪西窗烛，却话巴山夜雨时。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "李商隐《夜雨寄北》",
      "出处/作者": "李商隐《夜雨寄北》"
    },
    {
      "文本": "锦瑟无端五十弦，一弦一柱思华年。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "李商隐《锦瑟》",
      "出处/作者": "李商隐《锦瑟》"
    },
    {
      "文本": "明月几时有？把酒问青天。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "苏轼《水调歌头》",
      "出处/作者": "苏轼《水调歌头》"
    },
    {
      "文本": "但愿人长久，千里共婵娟。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "苏轼《水调歌头》",
      "出处/作者": "苏轼《水调歌头》"
    },
    {
      "文本": "大江东去，浪淘尽，千古风流人物。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "苏轼《念奴娇·赤壁怀古》",
      "出处/作者": "苏轼《念奴娇·赤壁怀古》"
    },
    {
      "文本": "人生如梦，一尊还酹江月。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "苏轼《念奴娇·赤壁怀古》",
      "出处/作者": "苏轼《念奴娇·赤壁怀古》"
    },
    {
      "文本": "十年生死两茫茫，不思量，自难忘。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "苏轼《江城子》",
      "出处/作者": "苏轼《江城子》"
    },
    {
      "文本": "莫听穿林打叶声，何妨吟啸且徐行。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "苏轼《定风波》",
      "出处/作者": "苏轼《定风波》"
    },
    {
      "文本": "竹杖芒鞋轻胜马，谁怕？一蓑烟雨任平生。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "苏轼《定风波》",
      "出处/作者": "苏轼《定风波》"
    },
    {
      "文本": "春色三分，二分尘土，一分流水。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "苏轼《水龙吟》",
      "出处/作者": "苏轼《水龙吟》"
    },
    {
      "文本": "缺月挂疏桐，漏断人初静。",
      "类别": "名句",
      "四部分类": "集部",
      "标题": "苏轼《卜算子》",
      "出处/作者": "苏轼《卜算子》"
    },
    {
      "文本": "莫道不消魂，帘卷西风，人比黄花瘦。",
